{
  "_comment": "Managed Settings — 組織全体に強制適用するセキュリティポリシー。MDM/設定管理ツールで全端末に配布。macOS: /Library/Application Support/ClaudeCode/managed-settings.json / Linux: /etc/claude-code/managed-settings.json",
  "_version": "1.0.0",
  "_reference": "docs/SECURITY_ARCHITECTURE.md, _common/DATA_PROTECTION.md",

  "enableAllProjectMcpServers": false,
  "disableBypassPermissionsMode": "disable",

  "_managed_controls_comment": "組織管理統制フラグ。true = ユーザーが個人設定で deny/hook/domain を上書き不可。上場準備企業では true を推奨（F-5 fix）。",
  "allowManagedPermissionRulesOnly": true,
  "allowManagedHooksOnly": true,
  "allowManagedDomainsOnly": true,

  "sandbox": {
    "_comment": "OS レベルサンドボックス。機密ファイルへの直接アクセスをブロック。",
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        "~/.aws/credentials",
        "~/.aws/config",
        "~/.ssh/id_*",
        "~/.ssh/config",
        "~/.gnupg/**",
        "~/.config/gh/hosts.yml",
        "~/.netrc"
      ]
    }
  },

  "permissions": {
    "_comment": "組織ポリシーとして強制。個人の settings.json より優先される。settings.json の deny リストと完全同期。",
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(chmod 777 *)",
      "Bash(chmod 0777 *)",
      "Bash(chmod a+rwx *)",
      "Bash(chmod ugo+rwx *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(: > *)",
      "Bash(mkfs *)",
      "Bash(dd if=*)",
      "Bash(osascript *)",
      "Bash(security *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(telnet *)",
      "Bash(python3 -c *)",
      "Bash(node -e *)",
      "Bash(node -r *)",
      "Bash(* .env*)",
      "Bash(* ~/.ssh/*)",
      "Bash(* ~/.aws/*)",
      "Bash(cat .env*)",
      "Bash(cat *secret*)",
      "Bash(cat *credential*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials.json)",
      "Read(**/.htpasswd)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Read(**/candidates*.csv)",
      "Read(**/applicants*.csv)",
      "Read(**/customer*.csv)",
      "Read(**/customer*.xlsx)",
      "Read(**/employee*.csv)",
      "Read(**/employee*.xlsx)",
      "Read(**/payroll*.csv)",
      "Read(**/payroll*.xlsx)",
      "Read(**/salary*.csv)",
      "Read(**/personal_data/**)",
      "Read(**/pii/**)",
      "Read(data/customers/**)",
      "Read(data/employees/**)",
      "Read(data/hr/**)",
      "Read(data/recruitment/**)",
      "Read(data/production/**)",
      "Read(data/prod/**)",
      "Read(**/*_backup.sql)",
      "Read(**/*.dump)",
      "Bash(cat *candidates*)",
      "Bash(cat *customer*)",
      "Bash(cat *employee*)",
      "Bash(cat *payroll*)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit -n *)",
      "Bash(python3 --command *)",
      "Bash(node --eval *)",
      "Write(.claude/hooks/*)",
      "Edit(.claude/hooks/*)",
      "Write(_templates/hooks/*)",
      "Edit(_templates/hooks/*)"
    ]
  }
}
