{
  "_comment": "LM Orchestrator — セキュリティ重視の推奨設定。install.sh --with-permissions で配布。enableAllProjectMcpServers:false = プロジェクトのMCPサーバーを自動有効化しない（CVE-2025-59536）。disableBypassPermissionsMode:disable = --dangerously-skip-permissions フラグを無効化（CVE-2026-21852）。トップレベルに置くこと（permissions オブジェクト内は無効）。",
  "enableAllProjectMcpServers": false,
  "disableBypassPermissionsMode": "disable",
  "sandbox": {
    "_comment": "サンドボックス設定。機密ファイルへの直接読み取りパスをブロックする。allowUnsandboxedCommands:false でdangerouslyDisableSandboxパラメータによる迂回をブロック。",
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        "~/.aws/credentials",
        "~/.aws/config",
        "~/.ssh/id_*",
        "~/.ssh/config",
        "~/.gnupg/**",
        "~/.config/gh/hosts.yml",
        "~/.netrc"
      ]
    },
    "_network_comment": "ネットワークホワイトリスト（推奨）。外部への意図しないデータ送信を防止。必要なドメインのみ許可してコメントアウトを外す。",
    "network": {
      "allowedDomains": [
        "api.anthropic.com",
        "github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org"
      ]
    }
  },
  "permissions": {
    "_comment": "allow: 明示的に許可するコマンド（最小権限）。deny: 危険・機密漏洩リスクのある操作を拒否。denyが優先される。[HIGH-7] npx * は allow にあるが tool-risk.js フックが npx -y を HIGH として ask_user する。allowはUI承認ダイアログのスキップのみでフックは常に実行される。",
    "allow": [
      "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pip *)",
      "Bash(python -m pytest *)",
      "Bash(python -m mypy *)",
      "Bash(python3 --version)",
      "Bash(python3 -m pytest *)",
      "Bash(python3 -m mypy *)",
      "Bash(node --version)",
      "Bash(ruff *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(tsc *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(git stash show *)",
      "Bash(git stash push *)",
      "Bash(git stash pop *)",
      "Bash(git stash apply *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh api *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(pwd)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod 0777 *)",
      "Bash(chmod a+rwx *)",
      "Bash(chmod ugo+rwx *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit -n *)",
      "Bash(: > *)",
      "Bash(mkfs *)",
      "Bash(dd if=*)",
      "Bash(osascript *)",
      "Bash(security *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(telnet *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(python3 -c *)",
      "Bash(python3 --command *)",
      "Bash(node -e *)",
      "Bash(node --eval *)",
      "Bash(node -r *)",
      "Bash(* .env*)",
      "Bash(* ~/.ssh/*)",
      "Bash(* ~/.aws/*)",
      "Bash(cat .env*)",
      "Bash(cat *secret*)",
      "Bash(cat *credential*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials.json)",
      "Read(**/.htpasswd)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Read(**/candidates*.csv)",
      "Read(**/applicants*.csv)",
      "Read(**/customer*.csv)",
      "Read(**/customer*.xlsx)",
      "Read(**/employee*.csv)",
      "Read(**/employee*.xlsx)",
      "Read(**/payroll*.csv)",
      "Read(**/payroll*.xlsx)",
      "Read(**/salary*.csv)",
      "Read(**/personal_data/**)",
      "Read(**/pii/**)",
      "Read(data/customers/**)",
      "Read(data/employees/**)",
      "Read(data/hr/**)",
      "Read(data/recruitment/**)",
      "Read(data/production/**)",
      "Read(data/prod/**)",
      "Read(**/*_backup.sql)",
      "Read(**/*.dump)",
      "Bash(cat *candidates*)",
      "Bash(cat *customer*)",
      "Bash(cat *employee*)",
      "Bash(cat *payroll*)",
      "Write(.claude/hooks/*)",
      "Edit(.claude/hooks/*)",
      "Write(_templates/hooks/*)",
      "Edit(_templates/hooks/*)"
    ]
  },
  "hooks": {
    "_comment": "フック設定。PreToolUse: ツール実行前リスク評価。PostToolUse: 実行後ログ記録。Elicitation: 情報収集リクエストのガード。Stop: セッションサマリ生成。",
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/tool-risk.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-use.js"
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/elicitation-guard.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop-hook.js"
          }
        ]
      }
    ]
  }
}
